generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  role          String    @default("ACCOUNTANT")
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  journalEntries JournalEntry[]
  bills          Bill[]
  invoices       Invoice[]
  expenses       Expense[]
  receipts       Receipt[]
  sessions       AppSession[]
}

model AppSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChartOfAccount {
  id          String   @id @default(cuid())
  accountNo   String   @unique
  fullName    String
  name        String
  parentNo    String?
  accountType String
  subType     String
  isActive    Boolean  @default(true)
  description String?
  balance     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journalLines  JournalLine[]
  billLines     BillLine[]
  invoiceLines  InvoiceLine[]
  expenseLines  ExpenseLine[]
}

model CostCenter {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  type        String   @default("PROJECT")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journalLines JournalLine[]
  billLines    BillLine[]
  invoiceLines InvoiceLine[]
}

model JournalEntry {
  id          String   @id @default(cuid())
  entryNo     String   @unique
  date        DateTime
  description String
  reference   String?
  status      String   @default("DRAFT")
  totalDebit  Float    @default(0)
  totalCredit Float    @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User          @relation(fields: [createdById], references: [id])
  lines     JournalLine[]
}

model JournalLine {
  id           String  @id @default(cuid())
  journalId    String
  accountId    String
  costCenterId String?
  description  String?
  debit        Float   @default(0)
  credit       Float   @default(0)
  taxRate      Float   @default(0)

  journal    JournalEntry   @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account    ChartOfAccount @relation(fields: [accountId], references: [id])
  costCenter CostCenter?    @relation(fields: [costCenterId], references: [id])
}

model Customer {
  id           String   @id @default(cuid())
  customerNo   String   @unique
  name         String
  email        String?
  phone        String?
  address      String?
  city         String?
  country      String?
  taxId        String?
  creditLimit  Float    @default(0)
  paymentTerms Int      @default(30)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  invoices     Invoice[]
}

model Vendor {
  id           String   @id @default(cuid())
  vendorNo     String   @unique
  name         String
  email        String?
  phone        String?
  address      String?
  city         String?
  country      String?
  taxId        String?
  paymentTerms Int      @default(30)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  bills        Bill[]
}

model Invoice {
  id          String    @id @default(cuid())
  invoiceNo   String    @unique
  customerId  String
  date        DateTime
  dueDate     DateTime
  status      String    @default("DRAFT")
  subtotal    Float     @default(0)
  taxAmount   Float     @default(0)
  total       Float     @default(0)
  amountPaid  Float     @default(0)
  balance     Float     @default(0)
  notes       String?
  terms       String?
  isRecurring Boolean   @default(false)
  recurringDay Int?
  nextDueDate DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer  Customer      @relation(fields: [customerId], references: [id])
  createdBy User          @relation(fields: [createdById], references: [id])
  lines     InvoiceLine[]
  payments  Payment[]
}

model InvoiceLine {
  id           String  @id @default(cuid())
  invoiceId    String
  accountId    String?
  costCenterId String?
  description  String
  quantity     Float   @default(1)
  unitPrice    Float   @default(0)
  taxRate      Float   @default(15)
  amount       Float   @default(0)

  invoice    Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  account    ChartOfAccount? @relation(fields: [accountId], references: [id])
  costCenter CostCenter?     @relation(fields: [costCenterId], references: [id])
}

model Bill {
  id          String   @id @default(cuid())
  billNo      String   @unique
  vendorId    String
  date        DateTime
  dueDate     DateTime
  status      String   @default("DRAFT")
  subtotal    Float    @default(0)
  taxAmount   Float    @default(0)
  total       Float    @default(0)
  amountPaid  Float    @default(0)
  balance     Float    @default(0)
  notes       String?
  reference   String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor    Vendor     @relation(fields: [vendorId], references: [id])
  createdBy User       @relation(fields: [createdById], references: [id])
  lines     BillLine[]
  payments  Payment[]
}

model BillLine {
  id           String  @id @default(cuid())
  billId       String
  accountId    String?
  costCenterId String?
  description  String
  quantity     Float   @default(1)
  unitPrice    Float   @default(0)
  taxRate      Float   @default(15)
  amount       Float   @default(0)

  bill       Bill            @relation(fields: [billId], references: [id], onDelete: Cascade)
  account    ChartOfAccount? @relation(fields: [accountId], references: [id])
  costCenter CostCenter?     @relation(fields: [costCenterId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  expenseNo   String   @unique
  date        DateTime
  description String
  category    String
  status      String   @default("PENDING")
  total       Float    @default(0)
  taxAmount   Float    @default(0)
  receiptId   String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User          @relation(fields: [createdById], references: [id])
  receipt   Receipt?      @relation(fields: [receiptId], references: [id])
  lines     ExpenseLine[]
}

model ExpenseLine {
  id          String  @id @default(cuid())
  expenseId   String
  accountId   String?
  description String
  amount      Float   @default(0)
  taxRate     Float   @default(0)

  expense Expense         @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  account ChartOfAccount? @relation(fields: [accountId], references: [id])
}

model Payment {
  id        String   @id @default(cuid())
  paymentNo String   @unique
  date      DateTime
  amount    Float
  method    String   @default("BANK_TRANSFER")
  reference String?
  notes     String?
  invoiceId String?
  billId    String?
  createdAt DateTime @default(now())

  invoice Invoice? @relation(fields: [invoiceId], references: [id])
  bill    Bill?    @relation(fields: [billId], references: [id])
}

model Employee {
  id          String   @id @default(cuid())
  employeeNo  String   @unique
  name        String
  email       String?
  phone       String?
  department  String?
  position    String?
  joiningDate DateTime
  salary      Float    @default(0)
  salaryType  String   @default("MONTHLY")
  bankAccount String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payrollEntries PayrollEntry[]
}

model PayrollEntry {
  id          String    @id @default(cuid())
  payrollNo   String    @unique
  employeeId  String
  period      String
  periodStart DateTime
  periodEnd   DateTime
  basicSalary Float     @default(0)
  allowances  Float     @default(0)
  deductions  Float     @default(0)
  taxAmount   Float     @default(0)
  netSalary   Float     @default(0)
  status      String    @default("DRAFT")
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee Employee      @relation(fields: [employeeId], references: [id])
  lines    PayrollLine[]
}

model PayrollLine {
  id          String @id @default(cuid())
  payrollId   String
  type        String
  description String
  amount      Float

  payroll PayrollEntry @relation(fields: [payrollId], references: [id], onDelete: Cascade)
}

model InventoryItem {
  id          String   @id @default(cuid())
  itemCode    String   @unique
  name        String
  description String?
  category    String?
  unit        String   @default("PCS")
  costPrice   Float    @default(0)
  salePrice   Float    @default(0)
  quantity    Float    @default(0)
  minQuantity Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaxRate {
  id        String   @id @default(cuid())
  name      String
  rate      Float
  type      String   @default("VAT")
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Receipt {
  id           String    @id @default(cuid())
  fileName     String
  filePath     String
  mimeType     String
  vendor       String?
  amount       Float?
  date         DateTime?
  description  String?
  status       String    @default("UNPROCESSED")
  uploadedById String
  createdAt    DateTime  @default(now())

  uploadedBy User      @relation(fields: [uploadedById], references: [id])
  expenses   Expense[]
}

model CompanySettings {
  id              String   @id @default(cuid())
  companyName     String   @default("NETKOM COMPANY FOR COMMUNICATION")
  legalName       String?
  taxId           String?
  address         String?
  city            String?
  country         String   @default("Saudi Arabia")
  phone           String?
  email           String?
  currency        String   @default("SAR")
  fiscalYearStart String   @default("01-01")
  zatcaEnabled    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Sequence {
  id     String @id @default(cuid())
  type   String @unique
  prefix String
  nextNo Int    @default(1)
}
